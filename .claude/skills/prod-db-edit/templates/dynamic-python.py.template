# ---- Optional: third-party HTTP via curl ------------------------------
# Cloudflare TLS-fingerprints Python's urllib/requests and returns the
# "Just a moment..." 403 challenge. curl negotiates HTTP/2 with a browser-
# shaped TLS profile and passes. Two parsing gotchas: HTTP/2 returns
# **lowercase** header names (`location`, not `Location`) and the Location
# header is sometimes a **relative** path — resolve against the request base.
_CURL = shutil.which("curl") or "/usr/bin/curl"


def _http_get(url: str, *, follow_redirects: bool = False) -> tuple[int, dict[str, str], bytes]:
    max_redirs = "50" if follow_redirects else "0"
    follow_flag = ["-L"] if follow_redirects else []
    with tempfile.NamedTemporaryFile() as body_f, tempfile.NamedTemporaryFile() as hdr_f:
        proc = subprocess.run(
            [
                _CURL, "-sS", *follow_flag, "--max-redirs", max_redirs,
                "-A", UA, "-o", body_f.name, "-D", hdr_f.name,
                "-w", "%{http_code}", "--max-time", "15", url,
            ],
            capture_output=True, check=False,
        )
        if proc.returncode != 0:
            raise RuntimeError(f"curl failed ({proc.returncode}): {proc.stderr.decode(errors='replace').strip()}")
        code = int(proc.stdout.decode().strip() or 0)
        body = body_f.read()
        hdr_text = hdr_f.read().decode("latin-1")
    blocks = [b for b in hdr_text.split("\r\n\r\n") if b.strip()]
    last_block = blocks[-1] if blocks else hdr_text
    headers: dict[str, str] = {}
    for line in last_block.split("\r\n"):
        if ":" in line and not line.startswith("HTTP/"):
            k, _, v = line.partition(":")
            headers[k.strip().lower()] = v.strip()  # lowercase per HTTP/2
    return code, headers, body
# ---- end Optional ----------------------------------------------------


