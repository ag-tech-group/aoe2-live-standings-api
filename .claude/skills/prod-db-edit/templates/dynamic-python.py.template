def _load_cache() -> dict[str, dict]:
    try:
        with open(CACHE_PATH) as f:
            return json.load(f)
    except FileNotFoundError:
        return {}


def _save_cache(cache: dict[str, dict]) -> None:
    with open(CACHE_PATH, "w") as f:
        json.dump(cache, f, indent=2, sort_keys=True)


def _resolve_lookups(keys: list[int]) -> dict[int, Lookup]:
    """Cache the lookup results so APPLY=1 re-uses the dry-run's mapping."""
    cache = _load_cache()
    lookups: dict[int, Lookup] = {}
    fetched_this_run = 0
    for i, k in enumerate(keys, start=1):
        ck = str(k)
        if ck in cache:
            e = cache[ck]
            lookups[k] = Lookup(k, e.get("matched_value"), e.get("skip_reason"))
            tag = "CACHED"
        else:
            if fetched_this_run > 0:
                time.sleep(THROTTLE_SECONDS)
            lk = _do_lookup(k)
            lookups[k] = lk
            cache[ck] = {"matched_value": lk.matched_value, "skip_reason": lk.skip_reason}
            fetched_this_run += 1
            tag = "FETCH "
        lk = lookups[k]
        status = "OK   " if lk.matched_value else "SKIP "
        info = lk.matched_value or lk.skip_reason
        print(f"  [{i:>3}/{len(keys)}] {tag} {k:>10}  {status}{info}")
    _save_cache(cache)
    return lookups


