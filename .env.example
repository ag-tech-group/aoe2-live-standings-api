# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aoe2_live_standings

# Environment
ENVIRONMENT=development

# CORS — comma-separated origins for production, e.g. "https://myapp.com,https://www.myapp.com"
CORS_ORIGINS=

# Logging
LOG_LEVEL=INFO

# OpenTelemetry (disabled by default)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=aoe2-live-standings-api
OTEL_EXPORTER_ENDPOINT=http://localhost:4317

# Feature flags — prefix with FEATURE_ and set to true/false
# FEATURE_NEW_DASHBOARD=true
# FEATURE_BETA_EXPORT=false

# Background tasks. Both default true so a single-process local dev runs
# everything. In prod they're split across two Cloud Run services: the
# api service has POLLING_ENABLED=false and the worker has
# LISTENER_ENABLED=false.
# POLLING_ENABLED=true
# LISTENER_ENABLED=true

# Authentication — the write/management API verifies the criticalbit_access
# cookie's JWT against criticalbit-auth-api's JWKS. Reads need no auth.
AUTH_JWKS_URL=https://auth-api.criticalbit.gg/auth/jwks
# AUTH_TOKEN_ISSUER=
